{
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/test_elevenlabs",
      "destination": "/api/test_elevenlabs.py"
    },
    {
      "source": "/api/hello",
      "destination": "/api/hello.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
